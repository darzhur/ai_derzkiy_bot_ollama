# Переменные окружения для Telegram бота с ChatGPT и YandexGPT

# Токен Telegram бота (получить можно у @BotFather в Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API ключ ProxyAPI (получить можно на https://proxyapi.ru)
# Используется для маршрутизации запросов через ProxyAPI к OpenAI (ChatGPT)
PROXYAPI_KEY=your_proxyapi_key_here

# Параметры YandexGPT (опционально, если не установлены - будет работать только ChatGPT)
# Folder ID из консоли Yandex Cloud
YANDEX_FOLDER_ID=your_yandex_folder_id_here

# IAM токен Yandex Cloud (чтобы получить: yc iam create-token)
YANDEX_AUTH_TOKEN=your_yandex_auth_token_here
